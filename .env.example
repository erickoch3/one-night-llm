# Export server variables in your shell before `npm run dev`; the local API
# process does not automatically load this file.

ONE_NIGHT_API_PORT=4318
NEXT_PUBLIC_GAME_API_URL=http://localhost:4318

# Optional: override installed-runtime discovery with an absolute executable.
# ONE_NIGHT_CODEX_EXECUTABLE=/absolute/path/to/codex

# Optional: relocate One Night's private Codex config and credential directory.
# ONE_NIGHT_CODEX_DATA_DIR=/absolute/private/path/one-night-codex

# Optional: use this server-side key for OpenAI API games. Players may instead
# enter a key in the local game setup; per-game keys are never persisted.
# OPENAI_API_KEY=sk-...
