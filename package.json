{
  "name": "one-night-llm",
  "version": "0.1.0",
  "private": true,
  "description": "A local multi-agent social-deduction game powered by Codex or deterministic rehearsal agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erickoch3/one-night-llm.git"
  },
  "bugs": {
    "url": "https://github.com/erickoch3/one-night-llm/issues"
  },
  "homepage": "https://github.com/erickoch3/one-night-llm#readme",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:api": "tsx watch server/index.ts",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test:unit": "tsx --test lib/agents/personalities.test.ts lib/game/game.test.ts tests/agent-prompts.test.ts tests/agent-vote-readiness.test.ts tests/codex-client.test.ts tests/dev-runtime.test.mjs tests/http.test.ts tests/personality-integration.test.ts tests/server-logic.test.ts",
    "test": "npm run typecheck && npm run test:unit && npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.21"
  },
  "type": "module"
}
